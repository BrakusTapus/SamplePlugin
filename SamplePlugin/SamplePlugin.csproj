<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
    <Import Project="Dalamud.Plugin.Bootstrap.targets"/>

    <PropertyGroup>
        <Authors>Kirbo</Authors>
        <Company></Company>
        <Version>0.0.0.1</Version>
        <Description>A sample plugin.</Description>
        <Copyright></Copyright>
        <PackageProjectUrl>https://github.com/goatcorp/SamplePlugin</PackageProjectUrl>
        <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <!-- Include all image files from the Images directory -->
    <ItemGroup>
        <!-- This includes the content in the build -->
        <Content Include="..\images\*.png">
            <!-- the next 3 tags work together and display the content from <content include> in the IDE -->
            <Link>images\%(Filename)%(Extension)</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <Visible>true</Visible>
        </Content>
    </ItemGroup>

</Project>
